<Window x:Class="TouristVoucher.ChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chart="clr-namespace:System.Windows.Controls.DataVisualization.Charting;assembly=System.Windows.Controls.DataVisualization.Toolkit"
        Title="📊 График поездок по месяцам" Height="500" Width="750"
        WindowStartupLocation="CenterOwner"
        Background="#F0F8FA">

    <Window.Resources>
        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0EEF3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08" Color="#7F8C8D"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock" x:Key="TitleStyle">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2C7A8C"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,15" Padding="15,10">
            <TextBlock Text="📊 Количество поездок по месяцам" Style="{StaticResource TitleStyle}"/>
        </Border>

        <!-- График -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="10">
            <chart:Chart Name="MonthlyChart" Title="Поездки по месяцам" 
                         Margin="10" Background="White">
                <chart:Chart.Series>
                    <chart:ColumnSeries Name="ColumnSeries" 
                                        Title="Количество поездок"
                                        IndependentValueBinding="{Binding Month}"
                                        DependentValueBinding="{Binding Count}"/>
                </chart:Chart.Series>
            </chart:Chart>
        </Border>
    </Grid>
</Window>