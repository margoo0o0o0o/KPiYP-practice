<Window x:Class="TouristVoucher.TripEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="✈️ Редактирование поездки" Height="520" Width="550"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F0F8FA">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2C7A8C"/>
            <Setter Property="BorderBrush" Value="#C2DFE8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="120"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E3F2F5"/>
                    <Setter Property="BorderBrush" Value="#9FC8D8"/>
                    <Setter Property="Foreground" Value="#1F5F6E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#F9FCFD"/>
            <Setter Property="BorderBrush" Value="#D0E2EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,3,0,10"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#F9FCFD"/>
            <Setter Property="BorderBrush" Value="#D0E2EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,3,0,10"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#F9FCFD"/>
            <Setter Property="BorderBrush" Value="#D0E2EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,3,0,10"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="#2C7A8C"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,5,0,2"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Турагент -->
            <TextBlock Grid.Row="0" Text="Турагент" Style="{StaticResource LabelStyle}"/>
            <ComboBox Grid.Row="1" Name="cboAgent" DisplayMemberPath="FullName"/>

            <!-- Номер группы -->
            <TextBlock Grid.Row="2" Text="Номер группы" Style="{StaticResource LabelStyle}"/>
            <ComboBox Grid.Row="3" Name="cboGroup" DisplayMemberPath="GroupNumber"/>

            <!-- Дата поездки -->
            <TextBlock Grid.Row="4" Text="Дата поездки" Style="{StaticResource LabelStyle}"/>
            <DatePicker Grid.Row="5" Name="dpTripDate"/>

            <!-- Длительность -->
            <TextBlock Grid.Row="6" Text="Длительность (дней)" Style="{StaticResource LabelStyle}"/>
            <TextBox Grid.Row="7" Name="txtDuration"/>

            <!-- Номер договора -->
            <TextBlock Grid.Row="8" Text="Номер договора" Style="{StaticResource LabelStyle}"/>
            <TextBox Grid.Row="9" Name="txtContract"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,10">
                <Button Name="btnSave" Content="💾 Сохранить" Width="130" Height="36" Margin="10,0" 
                        Style="{StaticResource ModernButton}" Click="btnSave_Click"/>
                <Button Name="btnCancel" Content="❌ Отмена" Width="130" Height="36" Margin="10,0" 
                        Style="{StaticResource ModernButton}" Click="btnCancel_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>