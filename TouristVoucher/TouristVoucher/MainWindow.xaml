<Window x:Class="TouristVoucher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Туристическая компания - Учет графика поездок" 
        Height="850" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        Background="#F0F8FA">

    <Window.Resources>
        <!-- Стиль для кнопок -->
        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2C7A8C"/>
            <Setter Property="BorderBrush" Value="#C2DFE8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.1" Color="#7F8C8D"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E3F2F5"/>
                    <Setter Property="BorderBrush" Value="#9FC8D8"/>
                    <Setter Property="Foreground" Value="#1F5F6E"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.15" Color="#7F8C8D"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D0E5EB"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#F5F5F5"/>
                    <Setter Property="Foreground" Value="#AAAAAA"/>
                    <Setter Property="BorderBrush" Value="#DDDDDD"/>
                    <Setter Property="Effect" Value="{x:Null}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для заголовков -->
        <Style TargetType="TextBlock" x:Key="SectionHeader">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C7A8C"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Стиль для карточек -->
        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0EEF3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08" Color="#7F8C8D"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Background="White" Margin="0,0,0,15" Padding="18,12">
            <TextBlock Text="🌊 Туристическая компания - Учет графика поездок и контроль виз" 
                       FontSize="18" FontWeight="Bold" 
                       Foreground="#2C7A8C" 
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Кнопки управления (первая строка) - увеличенные кнопки -->
        <WrapPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,8">
            <Button Name="btnLoad" Content="📂 Загрузить данные" Width="148" Margin="4" 
            Style="{StaticResource ModernButton}" Click="btnLoad_Click"/>
            <Button Name="btnShowAll" Content="📋 Все поездки" Width="115" Margin="4" 
            Style="{StaticResource ModernButton}" Click="btnShowAll_Click" IsEnabled="False"/>
            <Button Name="btnShowUpcoming" Content="⏳ Предстоящие" Width="125" Margin="4" 
            Style="{StaticResource ModernButton}" Click="btnShowUpcoming_Click" IsEnabled="False"/>
            <Button Name="btnShowPast" Content="📅 Прошедшие" Width="115" Margin="4" 
            Style="{StaticResource ModernButton}" Click="btnShowPast_Click" IsEnabled="False"/>
            <Button Name="btnCheckVisa" Content="🛂 Проверить визы" Width="140" Margin="4" 
            Style="{StaticResource ModernButton}" Click="btnCheckVisa_Click" IsEnabled="False"/>
            <Button Name="btnReset" Content="🔄 Сбросить" Width="100" Margin="4" 
            Style="{StaticResource ModernButton}" Click="btnReset_Click" IsEnabled="False"/>
        </WrapPanel>

        <!-- Панель управления данными (вторая строка) -->
        <WrapPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,8">
            <Button Name="btnManageAgents" Content="👤 Управление агентами" Width="170" Margin="4" 
                    Style="{StaticResource ModernButton}" Click="btnManageAgents_Click" IsEnabled="False"/>
            <Button Name="btnManageGroups" Content="👥 Управление группами" Width="180" Margin="4" 
                    Style="{StaticResource ModernButton}" Click="btnManageGroups_Click" IsEnabled="False"/>
            <Button Name="btnManageTrips" Content="✈️ Управление поездками" Width="180" Margin="4" 
                    Style="{StaticResource ModernButton}" Click="btnManageTrips_Click" IsEnabled="False"/>
            <Button Name="btnExportCSV" Content="📎 Экспорт в CSV" Width="130" Margin="4" 
                    Style="{StaticResource ModernButton}" Click="btnExportCSV_Click" IsEnabled="False"/>
            <Button Name="btnShowChart" Content="📊 График поездок" Width="140" Margin="4" 
                    Style="{StaticResource ModernButton}" Click="btnShowChart_Click" IsEnabled="False"/>
        </WrapPanel>

        <!-- Панель поиска -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,5,0,12" Padding="12">
            <StackPanel>
                <TextBlock Text="🔍 Поиск и фильтрация" FontWeight="SemiBold" Foreground="#2C7A8C" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Турагент:" Foreground="#5A7F8A" Margin="5,5,5,0"/>
                    <TextBox Grid.Row="1" Grid.Column="0" Name="txtSearchAgent" Margin="5" Height="32" 
                             Background="#F9FCFD" BorderBrush="#D0E2EA" BorderThickness="1" Padding="8"
                             FontSize="12"/>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Номер группы:" Foreground="#5A7F8A" Margin="5,5,5,0"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Name="txtSearchGroup" Margin="5" Height="32" 
                             Background="#F9FCFD" BorderBrush="#D0E2EA" BorderThickness="1" Padding="8"
                             FontSize="12"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Дата с:" Foreground="#5A7F8A" Margin="5,5,5,0"/>
                    <DatePicker Grid.Row="1" Grid.Column="2" Name="dpDateFrom" Margin="5" Height="32" 
                                Background="#F9FCFD" BorderBrush="#D0E2EA"/>

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Дата по:" Foreground="#5A7F8A" Margin="5,5,5,0"/>
                    <DatePicker Grid.Row="1" Grid.Column="3" Name="dpDateTo" Margin="5" Height="32" 
                                Background="#F9FCFD" BorderBrush="#D0E2EA"/>

                    <StackPanel Grid.Row="1" Grid.Column="4" Orientation="Horizontal" Margin="5">
                        <Button Name="btnSearch" Content="🔍 Найти" Width="85" Height="32" Margin="2" 
                                Style="{StaticResource ModernButton}" Click="btnSearch_Click"/>
                        <Button Name="btnClearSearch" Content="✖️ Сброс" Width="85" Height="32" Margin="2" 
                                Style="{StaticResource ModernButton}" Click="btnClearSearch_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Таблица поездок с вертикальным скроллингом -->
        <TextBlock Grid.Row="4" Text="✈️ График поездок" Style="{StaticResource SectionHeader}" Margin="0,5,0,3"/>
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="0,25,0,0">
            <DataGrid Name="dgTrips" 
                      AutoGenerateColumns="True" 
                      IsReadOnly="True" 
                      SelectionChanged="dgTrips_SelectionChanged"
                      MinWidth="1100"
                      Background="White"
                      BorderBrush="#E0EEF3"
                      BorderThickness="1"
                      RowHeight="35"
                      FontSize="12"
                      AlternatingRowBackground="#FAFDFF"
                      HeadersVisibility="Column"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E6F4F5"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#D4ECF0"/>
                                <Setter Property="Foreground" Value="#1F5F6E"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#D9F0F5"/>
                        <Setter Property="Foreground" Value="#2C7A8C"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Height" Value="38"/>
                        <Setter Property="BorderBrush" Value="#C8E2E8"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
            </DataGrid>
        </ScrollViewer>

        <!-- Разделитель -->
        <Separator Grid.Row="5" Margin="0,15" Height="1" Background="#D0E5EB"/>

        <!-- Информация о выбранной поездке -->
        <Border Grid.Row="6" Style="{StaticResource CardStyle}" Padding="12" Margin="0,5">
            <StackPanel>
                <TextBlock Text="📌 Детальная информация о выбранной поездке" 
                           FontWeight="SemiBold" Foreground="#2C7A8C" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="📅 Информация о поездке" FontWeight="Bold" Foreground="#2C7A8C" Margin="0,0,0,5"/>
                        <TextBlock Name="txtTripAgent" Text="Турагент: -" Foreground="#5A7F8A" Margin="0,2"/>
                        <TextBlock Name="txtTripGroup" Text="Группа: -" Foreground="#5A7F8A" Margin="0,2"/>
                        <TextBlock Name="txtTripPeriod" Text="Период: -" Foreground="#5A7F8A" Margin="0,2"/>
                        <TextBlock Name="txtContract" Text="Договор: -" Foreground="#5A7F8A" Margin="0,2"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="👥 Информация о группе" FontWeight="Bold" Foreground="#2C7A8C" Margin="0,0,0,5"/>
                        <TextBlock Name="txtGroupPeople" Text="Количество: -" Foreground="#5A7F8A" Margin="0,2"/>
                        <TextBlock Name="txtGroupCategory" Text="Категория: -" Foreground="#5A7F8A" Margin="0,2"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="🆔 Информация о турагенте" FontWeight="Bold" Foreground="#2C7A8C" Margin="0,0,0,5"/>
                        <TextBlock Name="txtAgentInsurance" Text="Страховое: -" Foreground="#5A7F8A" Margin="0,2"/>
                        <TextBlock Name="txtAgentINN" Text="ИНН: -" Foreground="#5A7F8A" Margin="0,2"/>
                        <TextBlock Name="txtAgentPassport" Text="Паспорт: -" Foreground="#5A7F8A" Margin="0,2"/>
                        <TextBlock Name="txtAgentVisa" Text="Срок визы: -" Foreground="#5A7F8A" Margin="0,2"/>
                        <TextBlock Name="txtAgentVisaStatus" Text="Статус визы: -" FontWeight="Bold" Margin="0,2"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Статистика -->
        <Border Grid.Row="7" Background="White" BorderBrush="#D9F0F5" BorderThickness="1" 
                Margin="0,12" Padding="12" CornerRadius="10">
            <WrapPanel HorizontalAlignment="Center">
                <TextBlock Name="txtTotalTrips" Text="🌊 Всего поездок: -" FontWeight="SemiBold" Foreground="#2C7A8C" Margin="20,0"/>
                <TextBlock Name="txtUpcomingTrips" Text="⏳ Предстоящих: -" FontWeight="SemiBold" Foreground="#5F9E6E" Margin="20,0"/>
                <TextBlock Name="txtPastTrips" Text="📅 Прошедших: -" FontWeight="SemiBold" Foreground="#8F9E9E" Margin="20,0"/>
                <TextBlock Name="txtVisaExpired" Text="⚠️ Агентов с просроч. визой: -" FontWeight="SemiBold" Foreground="#E8A87C" Margin="20,0"/>
            </WrapPanel>
        </Border>

        <!-- Статусная строка -->
        <StatusBar Grid.Row="8" VerticalAlignment="Bottom" Margin="0,5,0,0" Background="Transparent">
            <StatusBarItem>
                <TextBlock Name="txtStatus" Text="✨ Готов к работе" Foreground="#8F9E9E" FontSize="11" FontStyle="Italic"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>