<Window x:Class="TouristVoucher.GroupEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="👥 Редактирование группы" Height="350" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F0F8FA">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2C7A8C"/>
            <Setter Property="BorderBrush" Value="#C2DFE8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="100"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E3F2F5"/>
                    <Setter Property="BorderBrush" Value="#9FC8D8"/>
                    <Setter Property="Foreground" Value="#1F5F6E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#F9FCFD"/>
            <Setter Property="BorderBrush" Value="#D0E2EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#F9FCFD"/>
            <Setter Property="BorderBrush" Value="#D0E2EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="#2C7A8C"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,3"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Номер группы" Style="{StaticResource LabelStyle}"/>
        <TextBox Grid.Row="1" Name="txtGroupNumber"/>

        <TextBlock Grid.Row="2" Text="Количество человек" Style="{StaticResource LabelStyle}"/>
        <TextBox Grid.Row="3" Name="txtPeopleCount"/>

        <TextBlock Grid.Row="4" Text="Возрастная категория" Style="{StaticResource LabelStyle}"/>
        <ComboBox Grid.Row="5" Name="cboAgeCategory" IsEditable="True">
            <ComboBoxItem Content="Взрослая (18-65)"/>
            <ComboBoxItem Content="Молодежная (18-35)"/>
            <ComboBoxItem Content="Семейная с детьми"/>
            <ComboBoxItem Content="Пенсионная (65+)"/>
            <ComboBoxItem Content="Смешанная"/>
        </ComboBox>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Name="btnSave" Content="💾 Сохранить" Width="110" Margin="10" 
                    Style="{StaticResource ModernButton}" Click="btnSave_Click"/>
            <Button Name="btnCancel" Content="❌ Отмена" Width="110" Margin="10" 
                    Style="{StaticResource ModernButton}" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>