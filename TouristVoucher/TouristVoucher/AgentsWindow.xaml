<Window x:Class="TouristVoucher.AgentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="👤 Управление турагентами" Height="550" Width="850"
        WindowStartupLocation="CenterOwner"
        Background="#F0F8FA">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2C7A8C"/>
            <Setter Property="BorderBrush" Value="#C2DFE8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.1" Color="#7F8C8D"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E3F2F5"/>
                    <Setter Property="BorderBrush" Value="#9FC8D8"/>
                    <Setter Property="Foreground" Value="#1F5F6E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0EEF3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="35"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFDFF"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#D9F0F5"/>
            <Setter Property="Foreground" Value="#2C7A8C"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderBrush" Value="#C8E2E8"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E6F4F5"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D4ECF0"/>
                    <Setter Property="Foreground" Value="#1F5F6E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid Name="dgAgents" AutoGenerateColumns="False" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Страховое" Binding="{Binding InsuranceNumber}" Width="120"/>
                <DataGridTextColumn Header="ИНН" Binding="{Binding INN}" Width="120"/>
                <DataGridTextColumn Header="Паспорт" Binding="{Binding PassportNumber}" Width="120"/>
                <DataGridTextColumn Header="Срок визы" Binding="{Binding VisaExpiryText}" Width="100"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding VisaStatus}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Name="btnAdd" Content="➕ Добавить" Width="125" Height="34" Margin="5" 
                    Style="{StaticResource ModernButton}" Click="btnAdd_Click"/>
            <Button Name="btnEdit" Content="✏️ Редактировать" Width="130" Height="34" Margin="5" 
                    Style="{StaticResource ModernButton}" Click="btnEdit_Click"/>
            <Button Name="btnDelete" Content="🗑️ Удалить" Width="125" Height="34" Margin="5" 
                    Style="{StaticResource ModernButton}" Click="btnDelete_Click"/>
            <Button Name="btnClose" Content="❌ Закрыть" Width="125" Height="34" Margin="5" 
                    Style="{StaticResource ModernButton}" Click="btnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>